# Database (Vercel Postgres or external)
DATABASE_URL="postgresql://..."

# Server
PORT=5000
NODE_ENV=production

# JWT Secret (change in production)
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# CORS
ALLOWED_ORIGINS="https://your-app.vercel.app"

# Frontend API URL
VITE_API_URL=/api
